TELEGRAM_BOT_TOKEN=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# PostgreSQL (required) — Alembic + runtime connect here.
# docker compose builds this from POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB.
# Host runs (e.g. alembic from your shell) use the compose-exposed 127.0.0.1:5432.
POSTGRES_USER=calorie
POSTGRES_PASSWORD=calorie
POSTGRES_DB=caloriebot
DATABASE_URL=postgresql://calorie:calorie@localhost:5432/caloriebot

DAILY_SUMMARY_TIME=21:00
DAILY_REVIEW_TIME=22:00

# Logging
LOG_LEVEL=INFO
LOG_FILE=./data/logs/bot.log
DEBUG=

# Photo storage
PHOTOS_DIR=./data/photos

# Active provider: openrouter | local | custom
LLM_PROVIDER=openrouter

# Local (Ollama)
LOCAL_MODEL=gemma3:27b
LOCAL_API_KEY=ollama

# Custom endpoint
CUSTOM_BASE_URL=
CUSTOM_MODEL=
CUSTOM_API_KEY=

# Piano practice coach
PIANO_CHAT_MODEL=google/gemini-flash-1.5
# PIANO_ANALYSIS_MODEL must accept audio input (input_audio content blocks).
# Known-good via OpenRouter: google/gemini-2.0-flash-001, google/gemini-2.5-flash,
# openai/gpt-4o-audio-preview (OpenAI audio preview accepts only wav/mp3, not ogg —
# Telegram voice is ogg/opus, so a Gemini model is the simplest default).
PIANO_ANALYSIS_MODEL=google/gemini-2.0-flash-001
PIANO_CHECKIN_TIME=19:00
PIANO_RECORDINGS_DIR=./data/piano_recordings
